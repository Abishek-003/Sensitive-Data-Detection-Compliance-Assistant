# Copy this file to `.env` and fill in real values locally.
# Keep `.env` out of git. Only commit this template.

# LLM provider adapter used by app/services/llm.py
# Supported values:
# - langchain
# - openai
LLM_PROVIDER=langchain

# Use one API key here. For OpenRouter use an OpenRouter key.
# For xAI/Grok or another OpenAI-compatible provider, use that provider's key.
LLM_API_KEY=your_api_key_here

# OpenAI-compatible base URL.
# OpenRouter: https://openrouter.ai/api/v1
# xAI/Grok: set to the provider's compatible endpoint
LLM_BASE_URL=https://openrouter.ai/api/v1

# Model name for the selected provider.
# Examples:
# - openai/gpt-4o-mini
# - xai/grok-2-latest
LLM_MODEL=openai/gpt-4o-mini

# Optional metadata shown to the provider.
LLM_APP_NAME=Sensitive RAG + Compliance
LLM_APP_URL=http://localhost:8501

# Set to 0 to disable all LLM calls.
ENABLE_LLM=1
